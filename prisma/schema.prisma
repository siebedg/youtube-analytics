generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Channel {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("oklch(0.58 0.22 27)")
  sortOrder Int      @default(0)
  videos    Video[]
  metrics   Metric[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Metric {
  id        String  @id @default(cuid())
  channelId String
  key       String
  label     String
  color     String
  unit      String  @default("number")
  sortOrder Int     @default(0)
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, key])
}

model Video {
  id        String   @id @default(cuid())
  channelId String
  title     String
  values    String
  sortOrder Int      @default(0)
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
